// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RuleType {
  DISCOUNT
  MARKUP
  TAX
  SURCHARGE
}

enum ValueType {
  PERCENTAGE
  FIXED
}

enum ComponentCategory {
  FRAME
  FORK
  GEAR_SYSTEM
  BRAKE_SYSTEM
  WHEELSET
  SADDLE
  HANDLEBAR
  ACCESSORY
}

model User {
  id             String               @id @default(uuid())
  email          String               @unique
  name           String?
  password       String
  role           String               @default("user") // e.g. "admin", "user"
  configurations CycleConfiguration[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@map("users")
}

model PricingRule {
  id          String    @id @default(uuid())
  name        String
  description String?
  ruleType    RuleType
  valueType   ValueType
  value       Decimal   @db.Decimal(10, 2)
  conditions  Json?     // Storing structured criteria e.g. { "minQuantity": 10, "productCategory": "BMX" }
  priority    Int       @default(0)
  isActive    Boolean   @default(true)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("pricing_rules")
}

model Component {
  id          String            @id @default(uuid())
  name        String            @unique
  slug        String            @unique
  description String?
  category    ComponentCategory
  parts       Part[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("components")
}

model Part {
  id                 String              @id @default(uuid())
  name               String
  slug               String              @unique
  componentId        String
  component          Component           @relation(fields: [componentId], references: [id], onDelete: Cascade)
  basePrice          Decimal             @db.Decimal(10, 2)
  compatibility      Json?               // Compatibility rules e.g. { "allowedSizes": ["M", "L"], "carbonFrameOnly": true }
  isActive           Boolean             @default(true)
  priceHistories     PriceHistory[]
  configurationParts ConfigurationPart[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([componentId])
  @@index([slug])
  @@map("parts")
}

model PriceHistory {
  id         String    @id @default(uuid())
  partId     String
  part       Part      @relation(fields: [partId], references: [id], onDelete: Cascade)
  price      Decimal   @db.Decimal(10, 2)
  validFrom  DateTime  @default(now())
  validUntil DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([partId])
  @@index([validFrom, validUntil])
  @@map("price_histories")
}

model CycleConfiguration {
  id                 String              @id @default(uuid())
  name               String
  userId             String?
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  totalPrice         Decimal             @db.Decimal(10, 2) @default(0)
  configurationParts ConfigurationPart[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([userId])
  @@map("cycle_configurations")
}

model ConfigurationPart {
  id                   String             @id @default(uuid())
  configurationId      String
  configuration        CycleConfiguration @relation(fields: [configurationId], references: [id], onDelete: Cascade)
  partId               String
  part                 Part               @relation(fields: [partId], references: [id], onDelete: Restrict)
  quantity             Int                @default(1)
  priceAtConfiguration Decimal            @db.Decimal(10, 2) // Captures current price to freeze transaction values
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@unique([configurationId, partId])
  @@index([configurationId])
  @@index([partId])
  @@map("configuration_parts")
}
